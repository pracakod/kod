<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Diagnostyka — VW Golf 1.9 TDI BLS 2009</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg: #0f1117;
      --bg2: #161b27;
      --bg3: #1e2535;
      --border: #2a3347;
      --text: #e2e8f0;
      --muted: #8892a4;
      --accent: #3b82f6;
      --accent2: #6366f1;
      --green: #22c55e;
      --yellow: #f59e0b;
      --red: #ef4444;
      --orange: #f97316;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Inter', sans-serif;
      line-height: 1.6;
      min-height: 100vh;
    }

    /* ── HEADER ── */
    header {
      background: linear-gradient(135deg, #0f1117 0%, #1a2540 50%, #0f1117 100%);
      border-bottom: 1px solid var(--border);
      padding: 2.5rem 2rem 2rem;
      position: relative;
      overflow: hidden;
    }
    header::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at 30% 50%, rgba(59,130,246,0.12) 0%, transparent 60%),
                  radial-gradient(ellipse at 70% 50%, rgba(99,102,241,0.08) 0%, transparent 60%);
    }
    .header-inner {
      max-width: 1100px;
      margin: 0 auto;
      position: relative;
    }
    .car-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: rgba(59,130,246,0.15);
      border: 1px solid rgba(59,130,246,0.3);
      border-radius: 999px;
      padding: 0.3rem 1rem;
      font-size: 0.75rem;
      font-weight: 600;
      color: #93c5fd;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      margin-bottom: 1rem;
    }
    header h1 {
      font-size: clamp(1.6rem, 4vw, 2.5rem);
      font-weight: 800;
      background: linear-gradient(135deg, #e2e8f0, #93c5fd);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      margin-bottom: 0.5rem;
    }
    header p.subtitle {
      color: var(--muted);
      font-size: 0.95rem;
    }
    .stats-row {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      margin-top: 1.8rem;
    }
    .stat-chip {
      background: var(--bg3);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 0.6rem 1.1rem;
      display: flex;
      flex-direction: column;
      gap: 0.1rem;
    }
    .stat-chip .label { font-size: 0.7rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; }
    .stat-chip .value { font-size: 1rem; font-weight: 700; color: var(--text); }

    /* ── LAYOUT ── */
    main {
      max-width: 1100px;
      margin: 0 auto;
      padding: 2rem 1.5rem 4rem;
      display: grid;
      gap: 1.5rem;
    }

    /* ── SECTION ── */
    section {
      background: var(--bg2);
      border: 1px solid var(--border);
      border-radius: 14px;
      overflow: hidden;
    }
    .section-header {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 1.1rem 1.5rem;
      border-bottom: 1px solid var(--border);
      background: var(--bg3);
    }
    .section-icon {
      font-size: 1.2rem;
    }
    .section-header h2 {
      font-size: 1rem;
      font-weight: 700;
      color: var(--text);
    }
    .section-body {
      padding: 1.5rem;
    }

    /* ── STATUS BADGES ── */
    .badge {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.2rem 0.65rem;
      border-radius: 999px;
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .badge-red    { background: rgba(239,68,68,0.15);  color: #fca5a5; border: 1px solid rgba(239,68,68,0.3); }
    .badge-yellow { background: rgba(245,158,11,0.15); color: #fcd34d; border: 1px solid rgba(245,158,11,0.3); }
    .badge-green  { background: rgba(34,197,94,0.15);  color: #86efac; border: 1px solid rgba(34,197,94,0.3); }
    .badge-blue   { background: rgba(59,130,246,0.15); color: #93c5fd; border: 1px solid rgba(59,130,246,0.3); }

    /* ── TABLE ── */
    .diag-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.9rem;
    }
    .diag-table thead th {
      text-align: left;
      padding: 0.6rem 1rem;
      font-size: 0.72rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--muted);
      background: var(--bg3);
      border-bottom: 1px solid var(--border);
    }
    .diag-table tbody tr {
      border-bottom: 1px solid rgba(42,51,71,0.6);
      transition: background 0.15s;
    }
    .diag-table tbody tr:last-child { border-bottom: none; }
    .diag-table tbody tr:hover { background: rgba(255,255,255,0.025); }
    .diag-table td {
      padding: 0.75rem 1rem;
      vertical-align: middle;
    }
    .mono {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.85rem;
    }

    /* ── FACT CARDS ── */
    .fact-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 1rem;
    }
    .fact-card {
      background: var(--bg3);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.1rem 1.2rem;
      position: relative;
      overflow: hidden;
    }
    .fact-card::before {
      content: '';
      position: absolute;
      left: 0; top: 0; bottom: 0;
      width: 3px;
      border-radius: 3px 0 0 3px;
    }
    .fact-card.confirmed::before  { background: var(--green); }
    .fact-card.warning::before    { background: var(--yellow); }
    .fact-card.danger::before     { background: var(--red); }
    .fact-card.excluded::before   { background: var(--muted); }

    .fact-card h3 {
      font-size: 0.9rem;
      font-weight: 700;
      margin-bottom: 0.4rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .fact-card p {
      font-size: 0.82rem;
      color: var(--muted);
      line-height: 1.5;
    }

    /* ── PRIORITY LIST ── */
    .priority-list {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .priority-item {
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: 1rem;
      background: var(--bg3);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1rem 1.2rem;
    }
    .pnum {
      width: 36px; height: 36px;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-weight: 800;
      font-size: 1rem;
      flex-shrink: 0;
    }
    .pnum-1 { background: rgba(239,68,68,0.2); color: #fca5a5; border: 1px solid rgba(239,68,68,0.4); }
    .pnum-2 { background: rgba(245,158,11,0.2); color: #fcd34d; border: 1px solid rgba(245,158,11,0.4); }
    .pnum-3 { background: rgba(245,158,11,0.15); color: #fcd34d; border: 1px solid rgba(245,158,11,0.3); }
    .pnum-4 { background: rgba(34,197,94,0.15); color: #86efac; border: 1px solid rgba(34,197,94,0.3); }

    .priority-item h3 { font-size: 0.92rem; font-weight: 700; }
    .priority-item p  { font-size: 0.81rem; color: var(--muted); margin-top: 0.2rem; }
    .cost-chip {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.78rem;
      font-weight: 600;
      color: #93c5fd;
      background: rgba(59,130,246,0.1);
      border: 1px solid rgba(59,130,246,0.2);
      border-radius: 6px;
      padding: 0.25rem 0.6rem;
      white-space: nowrap;
    }

    /* ── VCDS BLOCK ── */
    .vcds-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 1rem;
    }
    .vcds-card {
      background: var(--bg3);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1rem;
    }
    .vcds-card .group {
      font-size: 0.68rem;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 0.6rem;
      font-weight: 600;
    }
    .vcds-card .param {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.35rem 0;
      border-bottom: 1px solid rgba(42,51,71,0.5);
      font-size: 0.82rem;
    }
    .vcds-card .param:last-child { border-bottom: none; }
    .vcds-card .param .name { color: var(--muted); }
    .vcds-card .param .val  { font-family: 'JetBrains Mono', monospace; font-weight: 600; font-size: 0.82rem; }
    .val-ok     { color: #86efac; }
    .val-warn   { color: #fcd34d; }
    .val-bad    { color: #fca5a5; }
    .val-neutral{ color: var(--text); }

    /* ── CONCLUSION BOX ── */
    .conclusion-box {
      background: linear-gradient(135deg, rgba(239,68,68,0.08), rgba(249,115,22,0.06));
      border: 1px solid rgba(239,68,68,0.25);
      border-radius: 12px;
      padding: 1.4rem 1.5rem;
    }
    .conclusion-box h3 {
      font-size: 1.05rem;
      font-weight: 800;
      margin-bottom: 0.75rem;
      color: #fca5a5;
    }
    .conclusion-box p {
      color: var(--text);
      font-size: 0.9rem;
      line-height: 1.7;
    }

    /* ── CHECKLIST ── */
    .checklist {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .checklist li {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      font-size: 0.88rem;
      color: var(--text);
      padding: 0.5rem 0.75rem;
      background: var(--bg3);
      border-radius: 8px;
      border: 1px solid var(--border);
    }
    .checklist li .icon { flex-shrink: 0; margin-top: 0.05rem; }
    .check-done  { border-left: 3px solid var(--green); }
    .check-todo  { border-left: 3px solid var(--yellow); }
    .check-no    { border-left: 3px solid var(--muted); opacity: 0.6; }

    /* ── FOOTER ── */
    footer {
      text-align: center;
      padding: 2rem;
      border-top: 1px solid var(--border);
      color: var(--muted);
      font-size: 0.78rem;
    }

    /* ── TABS ── */
    .tab-nav {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 1.5rem;
      display: flex;
      gap: 0.5rem;
      border-bottom: 2px solid var(--border);
      background: var(--bg);
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .tab-btn {
      padding: 0.9rem 1.4rem;
      background: none;
      border: none;
      border-bottom: 3px solid transparent;
      color: var(--muted);
      font-family: 'Inter', sans-serif;
      font-size: 0.9rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
      margin-bottom: -2px;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .tab-btn:hover { color: var(--text); }
    .tab-btn.active {
      color: #93c5fd;
      border-bottom-color: #3b82f6;
    }
    .tab-content { display: none; }
    .tab-content.active { display: block; }

    /* ── PLAN NAPRAWY ── */
    .plan-phase {
      background: var(--bg2);
      border: 1px solid var(--border);
      border-radius: 14px;
      overflow: hidden;
      margin-bottom: 1.5rem;
    }
    .plan-phase-header {
      padding: 1rem 1.5rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      border-bottom: 1px solid var(--border);
    }
    .plan-phase-header.phase-1 { background: rgba(239,68,68,0.12); }
    .plan-phase-header.phase-2 { background: rgba(245,158,11,0.12); }
    .plan-phase-header.phase-3 { background: rgba(59,130,246,0.12); }
    .plan-phase-header.phase-4 { background: rgba(34,197,94,0.12); }
    .plan-phase-header h2 { font-size: 1rem; font-weight: 800; }
    .phase-1 h2 { color: #fca5a5; }
    .phase-2 h2 { color: #fcd34d; }
    .phase-3 h2 { color: #93c5fd; }
    .phase-4 h2 { color: #86efac; }
    .plan-step {
      display: grid;
      grid-template-columns: 32px 1fr auto;
      align-items: flex-start;
      gap: 1rem;
      padding: 1rem 1.5rem;
      border-bottom: 1px solid rgba(42,51,71,0.5);
      transition: background 0.15s;
    }
    .plan-step:last-child { border-bottom: none; }
    .plan-step:hover { background: rgba(255,255,255,0.02); }
    .plan-step input[type=checkbox] {
      width: 20px; height: 20px;
      accent-color: #3b82f6;
      cursor: pointer;
      margin-top: 0.15rem;
      flex-shrink: 0;
    }
    .plan-step .step-body h3 {
      font-size: 0.92rem;
      font-weight: 700;
      margin-bottom: 0.3rem;
    }
    .plan-step .step-body p {
      font-size: 0.82rem;
      color: var(--muted);
      line-height: 1.55;
    }
    .plan-step .step-body code {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.78rem;
      background: var(--bg3);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 0.1rem 0.4rem;
      color: #93c5fd;
    }
    .plan-step.done { opacity: 0.5; }
    .plan-step.done .step-body h3 { text-decoration: line-through; }
    .parts-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 1rem;
    }
    .part-card {
      background: var(--bg3);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1rem;
    }
    .part-card .part-name { font-weight: 700; font-size: 0.9rem; margin-bottom: 0.4rem; }
    .part-card .part-detail { font-size: 0.8rem; color: var(--muted); line-height: 1.5; }
    .part-card .part-price { margin-top: 0.5rem; font-family: 'JetBrains Mono', monospace; font-size: 0.82rem; color: #93c5fd; font-weight: 600; }
    .morning-steps {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .morning-step {
      background: var(--bg3);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1rem 1.2rem;
      display: grid;
      grid-template-columns: 40px 1fr;
      gap: 1rem;
      align-items: flex-start;
    }
    .step-num {
      width: 36px; height: 36px;
      border-radius: 50%;
      background: rgba(59,130,246,0.2);
      border: 1px solid rgba(59,130,246,0.4);
      color: #93c5fd;
      font-weight: 800;
      display: flex; align-items: center; justify-content: center;
      font-size: 1rem;
      flex-shrink: 0;
    }
    .morning-step h3 { font-size: 0.92rem; font-weight: 700; margin-bottom: 0.3rem; }
    .morning-step p { font-size: 0.82rem; color: var(--muted); line-height: 1.55; }
    .vcds-cmd {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 0.5rem 0.75rem;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.78rem;
      color: #86efac;
      margin-top: 0.5rem;
      display: block;
    }
    .result-box {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.5rem;
      margin-top: 0.5rem;
    }
    .result-ok, .result-bad {
      padding: 0.4rem 0.7rem;
      border-radius: 6px;
      font-size: 0.78rem;
      font-weight: 600;
    }
    .result-ok  { background: rgba(34,197,94,0.12); border: 1px solid rgba(34,197,94,0.3); color: #86efac; }
    .result-bad { background: rgba(239,68,68,0.12); border: 1px solid rgba(239,68,68,0.3); color: #fca5a5; }

    /* ── RESPONSIVE ── */
    @media (max-width: 640px) {
      .priority-item { grid-template-columns: auto 1fr; }
      .cost-chip { display: none; }
      .stats-row { gap: 0.6rem; }
      .result-box { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<!-- ═══════════════ HEADER ═══════════════ -->
<header>
  <div class="header-inner">
    <div class="car-badge">🔧 Dokumentacja diagnostyczna</div>
    <h1>VW Golf V — 1.9 TDI BLS</h1>
    <p class="subtitle">Analiza usterki DPF / Czujnik G450 / Elektryka — opracowana z VCDS</p>
    <div class="stats-row">
      <div class="stat-chip"><span class="label">Rok produkcji</span><span class="value">2009</span></div>
      <div class="stat-chip"><span class="label">Silnik</span><span class="value">1.9 TDI BLS</span></div>
      <div class="stat-chip"><span class="label">Przebieg</span><span class="value">370 000 km</span></div>
      <div class="stat-chip"><span class="label">ECU Label</span><span class="value mono">03G-906-021-BLS.CLB</span></div>
      <div class="stat-chip"><span class="label">VCDS</span><span class="value">24.7 / 25.3</span></div>
      <div class="stat-chip"><span class="label">DPF</span><span class="value">Oryginalny</span></div>
    </div>
  </div>
</header>

<!-- ═══ TAB NAV ═══ -->
<nav class="tab-nav">
  <button class="tab-btn active" onclick="switchTab('diagnostyka', this)">📊 Diagnostyka</button>
  <button class="tab-btn" onclick="switchTab('plan', this)">🔧 Plan naprawy</button>
</nav>

<!-- ═══ TAB: DIAGNOSTYKA ═══ -->
<div id="tab-diagnostyka" class="tab-content active">
<main>

  <!-- ═══ DANE VCDS ═══ -->
  <section>
    <div class="section-header">
      <span class="section-icon">📊</span>
      <h2>Dane z VCDS — Bloki pomiarowe</h2>
    </div>
    <div class="section-body">
      <div class="vcds-grid">

        <div class="vcds-card">
          <div class="group">Gr. 001 — Injection Quantity</div>
          <div class="param"><span class="name">Engine Speed</span><span class="val val-ok">777 /min</span></div>
          <div class="param"><span class="name">Injection Quantity</span><span class="val val-warn">4.4 mg/suw</span></div>
          <div class="param"><span class="name">Injection Duration</span><span class="val val-neutral">7.7 KW</span></div>
          <div class="param"><span class="name">Coolant Temp</span><span class="val val-ok">61.2 °C</span></div>
        </div>

        <div class="vcds-card">
          <div class="group">Gr. 004 — Unit Injector</div>
          <div class="param"><span class="name">Engine Speed</span><span class="val val-ok">777 /min</span></div>
          <div class="param"><span class="name">Injection Start</span><span class="val val-ok">1.2 *PGMP</span></div>
          <div class="param"><span class="name">Injection Duration</span><span class="val val-ok">7.7 KW</span></div>
          <div class="param"><span class="name">Torsion Value (po)</span><span class="val val-ok">0.0 KW ✓</span></div>
          <div class="param"><span class="name">Torsion Value (przed)</span><span class="val val-bad">−3.9 KW ✗</span></div>
        </div>

        <div class="vcds-card">
          <div class="group">Gr. 005 — Start Conditions</div>
          <div class="param"><span class="name">Start Inj. Quantity</span><span class="val val-ok">9.6 mg/suw</span></div>
          <div class="param"><span class="name">Start Synchronisation</span><span class="val val-ok">48.0</span></div>
          <div class="param"><span class="name">Coolant Temp</span><span class="val val-ok">58.5 °C</span></div>
        </div>

        <div class="vcds-card">
          <div class="group">Gr. 067 — DPF Exhaust Gas I</div>
          <div class="param"><span class="name">Temp przed turbo</span><span class="val val-ok">42.0 °C</span></div>
          <div class="param"><span class="name">Temp w DPF</span><span class="val val-ok">42.0 °C</span></div>
          <div class="param"><span class="name">Press. Difference DPF</span><span class="val val-warn">15.30 mbar</span></div>
          <div class="param"><span class="name">Press. Diff. Offset ⚠️</span><span class="val val-bad">7.65 mbar</span></div>
        </div>

        <div class="vcds-card">
          <div class="group">Gr. 068 — DPF Exhaust Gas II</div>
          <div class="param"><span class="name">DPF Load Coefficient</span><span class="val val-warn">44.2 %</span></div>
          <div class="param"><span class="name">DPF Carbon Mass</span><span class="val val-warn">10.0</span></div>
          <div class="param"><span class="name">Carbon Mass Learned</span><span class="val val-neutral">0.0 %</span></div>
        </div>

        <div class="vcds-card">
          <div class="group">Gr. 073 — Particle Filter Data</div>
          <div class="param"><span class="name">Consumption since Regen</span><span class="val val-ok">2.4 l</span></div>
          <div class="param"><span class="name">Distance since Regen</span><span class="val val-ok">50 km</span></div>
          <div class="param"><span class="name">Time since Regen</span><span class="val val-ok">60.0 min</span></div>
        </div>

        <div class="vcds-card">
