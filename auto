<script>
function switchTab(tabId, btn) {
  document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + tabId).classList.add('active');
  btn.classList.add('active');
  window.scrollTo({top: 0, behavior: 'smooth'});
}

function toggleDone(checkbox) {
  const step = checkbox.closest('.plan-step');
  step.classList.toggle('done', checkbox.checked);
  saveProgress();
}

function saveProgress() {
  const state = {};
  document.querySelectorAll('.plan-step').forEach(step => {
    if (step.id) state[step.id] = step.querySelector('input').checked;
  });
  try { localStorage.setItem('golf_bls_plan', JSON.stringify(state)); } catch(e) {}
}

function loadProgress() {
  try {
    const state = JSON.parse(localStorage.getItem('golf_bls_plan') || '{}');
    document.querySelectorAll('.plan-step').forEach(step => {
      if (step.id && state[step.id]) {
        step.querySelector('input').checked = true;
        step.classList.add('done');
      }
    });
  } catch(e) {}
}

loadProgress();
</script>

